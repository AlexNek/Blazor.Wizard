@using Blazor.Wizard.Demo.Components.WizardLogic.Detective
@using Blazor.Wizard.Demo.Models.Detective

<EditForm EditContext="EditContext" class="detective-step-card">
    <DataAnnotationsValidator/>
    <h3 class="detective-step-title">Your Answer</h3>
    <p class="detective-step-caption">Now decide suspect, method, and motive.</p>

    <div class="detective-field">
        <label for="suspectSelect">Suspect</label>
        <InputSelect id="suspectSelect" @bind-Value="Model.Suspect" class="detective-select">
            <option value="">-- Select suspect --</option>
            <option value="@DetectiveCaseFacts.CorrectSuspect">Ivy Marlowe (concert pianist)</option>
            <option value="Marcos Vale (groundskeeper)">Marcos Vale (groundskeeper)</option>
            <option value="Nora Flint (estate lawyer)">Nora Flint (estate lawyer)</option>
        </InputSelect>
        <ValidationMessage For="@(() => Model.Suspect)" class="detective-validation"/>
    </div>

    <div class="detective-field">
        <label for="methodSelect">Method</label>
        <InputSelect id="methodSelect" @bind-Value="Model.MurderMethod" class="detective-select">
            <option value="">-- Select method --</option>
            <option value="@DetectiveCaseFacts.CorrectMethod">Poison in tea</option>
            <option value="Electric shock with floor lamp">Electric shock with floor lamp</option>
            <option value="Hit with metronome">Hit with metronome</option>
        </InputSelect>
        <ValidationMessage For="@(() => Model.MurderMethod)" class="detective-validation"/>
    </div>

    <div class="detective-field">
        <label for="motiveSelect">Motive</label>
        <InputSelect id="motiveSelect" @bind-Value="Model.Motive" class="detective-select">
            <option value="">-- Select motive --</option>
            <option value="@DetectiveCaseFacts.CorrectMotive">Money and inheritance</option>
            <option value="Professional jealousy">Professional jealousy</option>
            <option value="Revenge for old family conflict">Revenge for old family conflict</option>
        </InputSelect>
        <ValidationMessage For="@(() => Model.Motive)" class="detective-validation"/>
    </div>
</EditForm>

@code {

    [Parameter]
    [EditorRequired]
    public required DetectiveAccusationStepModel Model { get; set; }

    [Parameter]
    [EditorRequired]
    public required EditContext EditContext { get; set; }

}
