@using Blazor.Wizard.Demo.Models.Detective

<EditForm EditContext="EditContext" class="detective-step-card">
    <DataAnnotationsValidator/>
    <h3 class="detective-step-title">Case: Music Room Death</h3>
    <p class="detective-step-caption">
        Elias Thorn died in the music room. The door was locked.
        It was raining. Find who did it.
    </p>

    <label class="detective-choice @(Model.ReadyToInvestigate ? "selected" : string.Empty)">
        <InputCheckbox @bind-Value="Model.ReadyToInvestigate"/>
        I am ready.
    </label>

    <ValidationMessage For="@(() => Model.ReadyToInvestigate)" class="detective-validation"/>
</EditForm>

@code {

    [Parameter]
    [EditorRequired]
    public required DetectiveCaseIntroStepModel Model { get; set; }

    [Parameter]
    [EditorRequired]
    public required EditContext EditContext { get; set; }

}
