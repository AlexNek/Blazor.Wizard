@using Blazor.Wizard.Demo.Components.WizardLogic.Detective
@using Blazor.Wizard.Demo.Models.Detective

<EditForm EditContext="EditContext" class="detective-step-card">
    <DataAnnotationsValidator/>
    <h3 class="detective-step-title">Lab Step</h3>
    <p class="detective-step-caption">Pick one clue.</p>

    <InputRadioGroup @bind-Value="Model.EvidenceChoice" Name="forensicsEvidence">
        <label class="detective-choice @(Model.EvidenceChoice == DetectiveCaseFacts.CorrectForensicEvidence ? "selected" : string.Empty)">
            <InputRadio Value="@DetectiveCaseFacts.CorrectForensicEvidence"/>
            Poison was in the tea. Black cloth fiber was on the window.
        </label>
        <label class="detective-choice @(Model.EvidenceChoice == WrongEvidenceOne ? "selected" : string.Empty)">
            <InputRadio Value="@WrongEvidenceOne"/>
            Muddy boot print was too big for all suspects.
        </label>
        <label class="detective-choice @(Model.EvidenceChoice == WrongEvidenceTwo ? "selected" : string.Empty)">
            <InputRadio Value="@WrongEvidenceTwo"/>
            Broken violin string had no DNA.
        </label>
    </InputRadioGroup>

    <ValidationMessage For="@(() => Model.EvidenceChoice)" class="detective-validation"/>
</EditForm>

@code {
    private const string WrongEvidenceOne = "Muddy boot print was too big.";

    private const string WrongEvidenceTwo = "Broken violin string had no DNA.";

    [Parameter]
    [EditorRequired]
    public required ForensicsEvidenceStepModel Model { get; set; }

    [Parameter]
    [EditorRequired]
    public required EditContext EditContext { get; set; }
}
