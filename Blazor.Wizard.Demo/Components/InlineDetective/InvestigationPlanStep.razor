@using Blazor.Wizard.Demo.Components.WizardLogic.Detective
@using Blazor.Wizard.Demo.Components.WizardLogic.Detective.Strategies
@using Blazor.Wizard.Demo.Models.Detective

<EditForm EditContext="EditContext" class="detective-step-card">
    <DataAnnotationsValidator/>
    <h3 class="detective-step-title">Choose Plan</h3>
    <p class="detective-step-caption">Choose witness questions, lab questions, or both.</p>

    <InputRadioGroup @bind-Value="Model.Strategy" Name="investigationStrategy">
        <label class="detective-choice @(Model.Strategy == InvestigationStrategyFactory.WitnessOnly ? "selected" : string.Empty)">
            <InputRadio Value="@InvestigationStrategyFactory.WitnessOnly" /> Witness only
        </label>
        <label class="detective-choice @(Model.Strategy == InvestigationStrategyFactory.ForensicsOnly ? "selected" : string.Empty)">
            <InputRadio Value="@InvestigationStrategyFactory.ForensicsOnly" /> Lab only
        </label>
        <label class="detective-choice @(Model.Strategy == InvestigationStrategyFactory.FullSweep ? "selected" : string.Empty)">
            <InputRadio Value="@InvestigationStrategyFactory.FullSweep" /> Witness and lab
        </label>
    </InputRadioGroup>

    <ValidationMessage For="@(() => Model.Strategy)" class="detective-validation"/>
</EditForm>

@code {

    [Parameter]
    [EditorRequired]
    public required InvestigationPlanStepModel Model { get; set; }

    [Parameter]
    [EditorRequired]
    public required EditContext EditContext { get; set; }

}
