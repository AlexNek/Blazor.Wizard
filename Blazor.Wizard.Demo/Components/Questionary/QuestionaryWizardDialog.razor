@using Blazor.Wizard.Demo.Components.WizardLogic.Questionary
@using Blazor.Wizard.Demo.Models
@implements IDisposable

@if (Visible)
{
    <div class="modal fade show d-block" tabindex="-1" style="background:rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Questionary Wizard</h5>
                    <button type="button" class="btn-close" @onclick="OnCancel" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    @if (_viewModel != null && _viewModel.Engine != null)
                    {
                        var stepState = _viewModel.CurrentStep;
                        var stepId = (EQuestionaryStepId)Enum.Parse(typeof(EQuestionaryStepId), stepState.Name);
                        var componentType = QuestionaryStepRegistry.GetComponentType(stepId);
                        var parameters = stepId == EQuestionaryStepId.Report
                            ? new Dictionary<string, object> { ["Model"] = _viewModel.CurrentStepModel }
                            : new Dictionary<string, object> { ["Model"] = _viewModel.CurrentStepModel, ["EditContext"] = stepState.EditContext };
                        
                        <DynamicComponent Type="@componentType" Parameters="@parameters" />
                    }
                </div>
                <div class="modal-footer d-flex justify-content-end gap-2 w-100">
                    <button class="btn btn-secondary" @onclick="OnCancel">Cancel</button>
                    <button class="btn btn-outline-primary" @onclick="OnBack" disabled="@(_viewModel == null || _viewModel.IsFirstStep)">Back</button>
                    @if (_viewModel != null)
                    {
                        if (!_viewModel.IsLastStep)
                        {
                            <button class="btn btn-primary" @onclick="OnNext" disabled="@(!_viewModel.CurrentStep.IsValid)">Next</button>
                        }
                        else
                        {
                            <button class="btn btn-primary" @onclick="OnOkClick" disabled="@(!_viewModel.CurrentStep.IsValid)">OK</button>
                        }
                    }
                </div>
            </div>
        </div>
    </div>
}
