@page "/"
@using Blazor.Wizard.Demo.Components.Person
@using Blazor.Wizard.Demo.Components.Questionary
@using Blazor.Wizard.Demo.Models

<h2>Wizard Demo - Native Dialog</h2>

<p>Clean wizard architecture with native Bootstrap popup dialog.</p>
<p class="text-muted">
    Person wizard demo uses two service patterns:
    toaster via <code>WizardData.AddService</code> and funny animation via constructor injection.
</p>

<button class="btn btn-primary" @onclick="OpenWizard">Person Wizard</button>
<button class="btn btn-primary ms-2" @onclick="OpenQuestionaryWizard">Questionary Wizard</button>
@if (!string.IsNullOrEmpty(_result))
{
    <div class="alert @(_isCanceled ? "alert-warning" : "alert-success") mt-3">
        <h5>@(_isCanceled ? "Canceled" : "Success!")</h5>
        <p>@_result</p>
    </div>
}

<PersonWizardDialog Visible="_showPersonDialog" VisibleChanged="@((bool v) => _showPersonDialog = v)"
                    Model="_model"
                    OnFinished="OnWizardFinished"/>

<QuestionaryWizardDialog Visible="_showQuestionaryDialog" VisibleChanged="@((bool v) => _showQuestionaryDialog = v)"
                         Model="_questionaryModel"
                         OnFinished="OnQuestionaryFinished"
                         OnCanceled="OnQuestionaryCanceled"/>

@code {

    private bool _showPersonDialog;

    private PersonModel _model = new() { Email = "demo@example.com" };

    private string _result = string.Empty;
    private bool _isCanceled;

    private bool _showQuestionaryDialog;

    private QuestionaryModel _questionaryModel = new();

    private void OpenWizard()
    {
        _result = string.Empty;
        _isCanceled = false;
        _showPersonDialog = true;
    }

    private void OpenQuestionaryWizard()
    {
        _questionaryModel = new QuestionaryModel();
        _result = string.Empty;
        _isCanceled = false;
        _showQuestionaryDialog = true;
    }

    private void OnWizardFinished(PersonModel model)
    {
        _model = model;
        _result = $"Welcome {model.FirstName} {model.LastName} from {model.City}, {model.Country}!";
        _isCanceled = false;
        _showPersonDialog = false;
    }

    private void OnQuestionaryFinished(QuestionaryModel model)
    {
        _result = $"Thank you, {model.Name}! Age: {model.Age}, Favorite Color: {model.FavoriteColor}.";
        _isCanceled = false;
        _showQuestionaryDialog = false;
    }

    private void OnQuestionaryCanceled()
    {
        _result = "Questionary wizard was canceled.";
        _isCanceled = true;
        _showQuestionaryDialog = false;
    }

}
