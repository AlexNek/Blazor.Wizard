@using Blazor.Wizard.DemoDevEx.Models
@using DevExpress.Blazor
@implements IDisposable

<DxPopup Visible="@Visible"
         VisibleChanged="@VisibleChanged"
         HeaderText="Person Information Wizard"
         Width="600px"
         ShowCloseButton="true"
         CloseOnEscape="true"
         ShowFooter="true">
  <BodyContentTemplate>
    <div style="padding: 20px;">
      @if (_viewModel?.Flow != null && _viewModel?.Steps != null && _viewModel.Flow.Index >= 0 && _viewModel.Flow.Index < _viewModel.Steps.Count)
      {
        var step = _viewModel.Steps[_viewModel.Flow.Index];
        if (step is PersonInfoStepLogic personStep)
        {
            <PersonInfoForm Model="@personStep.GetModel()" EditContext="@personStep.GetEditContext()"/>
        }
        else if (step is AddressStepLogic addressStep)
        {
            <AddressForm Model="@addressStep.GetModel()" EditContext="@addressStep.GetEditContext()"/>
        }
        else if (step is PensionInfoStepLogic pensionStep)
        {
            <PensionInfoForm Model="@pensionStep.GetModel()" EditContext="@pensionStep.GetEditContext()"/>
        }
        else if (step is SummaryStepLogic)
        {
            var personStep0 = _viewModel.Steps[0] as PersonInfoStepLogic;
            var resultModel = new PersonModelResultBuilder().Build(_viewModel.Data);
            <SummaryView Model="@resultModel" DemoParameter="@personStep0?.DemoParameter"/>
        }
      }
    </div>
  </BodyContentTemplate>
  <FooterContentTemplate>
    <div class="d-flex justify-content-end gap-2 w-100">
      <DxButton Text="Cancel"
                Click="@OnCancel"
                RenderStyle="ButtonRenderStyle.Secondary"/>
      <DxButton Text="Back"
                Enabled="@(_viewModel?.Flow != null && _viewModel?.Steps != null && _viewModel.Flow.Index > 0 && Enumerable.Range(0, _viewModel.Flow.Index).Any(i => _viewModel.Steps[i].IsVisible))"
                Click="@OnBack"/>
      @if (_viewModel?.Flow != null && _viewModel?.Steps != null && _viewModel.Flow.Index >= 0 && _viewModel.Flow.Index < _viewModel.Steps.Count)
      {
        if (_viewModel.Flow.Index < _viewModel.Steps.Count - 1 && Enumerable.Range(_viewModel.Flow.Index + 1, _viewModel.Steps.Count - _viewModel.Flow.Index - 1).Any(i => _viewModel.Steps[i].IsVisible))
        {
          <DxButton Text="Next"
                    Click="@OnNext"
                    RenderStyle="ButtonRenderStyle.Primary"
                    Enabled="@_viewModel.CanProceed"/>
        }
        else
        {
          <DxButton Text="OK"
                    Click="@OnOkClick"
                    RenderStyle="ButtonRenderStyle.Primary"
                    Enabled="@_viewModel.CanProceed"/>
        }
      }
    </div>
  </FooterContentTemplate>
</DxPopup>

@code {

  [Parameter]
  public bool Visible { get; set; }

  [Parameter]
  public EventCallback<bool> VisibleChanged { get; set; }

  [Parameter]
  public PersonModel Model { get; set; } = new();

  [Parameter]
  public EventCallback<PersonModel> OnFinished { get; set; }

  private PersonWizardViewModel? _viewModel;

  protected override async Task OnParametersSetAsync()
  {
    if (Visible && _viewModel == null)
    {
      _viewModel = new PersonWizardViewModel();
      _viewModel.StateChanged += OnViewModelStateChanged;
      _viewModel.Initialize(null);
      await _viewModel.StartAsync();
      StateHasChanged();
    }
  }
  
  private void OnViewModelStateChanged()
  {
    StateHasChanged();
  }

  private async Task OnNext()
  {
    if (_viewModel != null)
    {
      var result = await _viewModel.NextAsync();
      StateHasChanged();
    }
  }

  private async Task OnBack()
  {
    if (_viewModel != null)
    {
      await _viewModel.BackAsync();
      StateHasChanged();
    }
  }

  private async Task OnOkClick()
  {
    if (_viewModel != null)
    {
      var result = await _viewModel.FinishAsync();
      if (result != null)
      {
        await OnFinished.InvokeAsync(result);
        Visible = false;
        await VisibleChanged.InvokeAsync(false);
        _viewModel.Reset();
        _viewModel = null;
      }
      StateHasChanged();
    }
  }

  private async Task OnCancel()
  {
    if (_viewModel != null)
    {
      _viewModel.Reset();
      _viewModel = null;
    }
    Visible = false;
    await VisibleChanged.InvokeAsync(false);
  }

  public void Dispose()
  {
    if (_viewModel != null)
    {
      _viewModel.StateChanged -= OnViewModelStateChanged;
      _viewModel.Reset();
    }
  }

}